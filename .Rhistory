) +
theme_minimal()
q_tercil_bajo <- quantile(train_clean$price_num, 1/3)
q_tercil_alto <- quantile(train_clean$price_num, 2/3)
resumen_precio_df <- data.frame(
Estadistico = c("N observaciones", "Media", "Mediana", "Desv. Estandar",
"Minimo", "P10", "P25 (Q1)", "P33 (tercil 1)",
"P50 (mediana)", "P67 (tercil 2)",
"P75 (Q3)", "P90", "P99", "Maximo"),
Valor_USD = c(
nrow(train_clean),
round(mean(train_clean$price_num), 1),
round(median(train_clean$price_num), 1),
round(sd(train_clean$price_num), 1),
round(min(train_clean$price_num), 1),
round(quantile(train_clean$price_num, 0.10), 1),
round(quantile(train_clean$price_num, 0.25), 1),
round(q_tercil_bajo, 1),
round(quantile(train_clean$price_num, 0.50), 1),
round(q_tercil_alto, 1),
round(quantile(train_clean$price_num, 0.75), 1),
round(quantile(train_clean$price_num, 0.90), 1),
round(quantile(train_clean$price_num, 0.99), 1),
round(max(train_clean$price_num), 1)
)
)
